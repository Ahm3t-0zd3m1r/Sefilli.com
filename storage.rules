rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Allow anyone to read all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow authenticated users to upload files
    // Files are usually stored in paths like 'profiles/', 'marketplace/', etc.
    match /{path=**} {
      allow write: if isSignedIn() && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }
  }
}
